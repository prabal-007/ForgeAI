# --- Required for LLM + cover images ---
OPENAI_API_KEY=

# --- Database (SQLAlchemy / PostgreSQL) ---
# Default in code matches local Postgres; override if needed.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/forgeai

# --- Cover generation ---
# COVER_MODE=programmatic  (default) — Pillow typographic cover, zero API cost, 100% legible text
# COVER_MODE=ai            — DALL-E image cover (opt-in, costs OpenAI tokens)
COVER_MODE=programmatic
COVER_STORAGE_MODE=local
COVER_STORAGE_DIR=./generated_covers

# Only used when COVER_MODE=ai:
# COVER_IMAGE_MODEL=dall-e-3
# COVER_IMAGE_SIZE=1024x1792
# COVER_TEXT_OVERLAY=true

# --- Optional: store covers on S3 (set COVER_STORAGE_MODE=s3) ---
# COVER_S3_BUCKET=
# COVER_S3_REGION=
